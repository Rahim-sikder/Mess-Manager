# Supabase — get these from your Supabase project > Settings > API
# The ANON key is safe for the browser; NEVER put the service_role key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend base URL — leave empty if the frontend and backend are on the same origin.
# In production set this to your Render backend URL:
#   VITE_API_BASE_URL=https://your-backend.onrender.com
VITE_API_BASE_URL=
